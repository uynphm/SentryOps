# ── Required secrets (set in GitHub Actions / Azure Container Apps) ────────────
ANTHROPIC_API_KEY=your-claude-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

SENTRYOPS_API_KEY=change-me-strong-random-key

# ── GitHub App (if using GitHub App mode) ────────────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN=ghp_your_pat_for_local_dev

# ── Azure (leave blank to run without Azure in dev) ──────────────────────────
AZURE_KEYVAULT_URL=
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=sentryops-audit-logs

# ── App config ────────────────────────────────────────────────────────────────
DEBUG=true
# Comma-separated list of allowed CORS origins (no wildcards in production)
# ALLOWED_ORIGINS=["https://sentryops.yourdomain.com"]
SCORE_PASS_THRESHOLD=60
SCORE_WARN_THRESHOLD=80
